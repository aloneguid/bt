<CPackWiXPatch>
    <CPackWiXFragment Id="CM_CP_bt.exe">

        <!-- custom protocol (x-bt) -->
        <RegistryKey Root="HKCU" Key="Software\Classes\x-bt\shell\open\command">
            <RegistryValue Type="string" Value='"[#CM_FP_bt.exe]" "%1"' />
        </RegistryKey>
        <RegistryKey Root="HKCU" Key="Software\Classes\x-bt">
            <RegistryValue Type="string" Value="URL:BrowserTamer Protocol" />
            <RegistryValue Type="string" Name="URL Protocol" Value="" />
        </RegistryKey>

        <!-- URL and File associations -->
        <RegistryKey Root="HKCU" Key="Software\Clients\StartMenuInternet\BrowserTamer">
            <RegistryValue Type="string" Value="Browser Tamer" />
        </RegistryKey>
        <RegistryKey Root="HKCU" Key="Software\Clients\StartMenuInternet\BrowserTamer\DefaultIcon">
            <RegistryValue Type="string" Value="[#CM_FP_bt.exe],0" />
        </RegistryKey>
        <RegistryKey Root="HKCU" Key="Software\Clients\StartMenuInternet\BrowserTamer\shell\open\command">
            <RegistryValue Type="string" Value="[#CM_FP_bt.exe]" />
        </RegistryKey>
        <RegistryKey Root="HKCU" Key="Software\Clients\StartMenuInternet\BrowserTamer\Capabilities">
            <RegistryValue Type="string" Name="ApplicationName" Value="Browser Tamer" />
            <RegistryValue Type="string" Name="ApplicationDescription" Value="Redirects open URLs to a browser of your choice." />
            <RegistryValue Type="string" Name="ApplicationIcon" Value="[#CM_FP_bt.exe],0" />
        </RegistryKey>
        <RegistryKey Root="HKCU" Key="Software\Clients\StartMenuInternet\BrowserTamer\Capabilities\URLAssociations">
            <RegistryValue Type="string" Name="x-bt" Value="BrowserTamerHTM" />
            <RegistryValue Type="string" Name="http" Value="BrowserTamerHTM" />
            <RegistryValue Type="string" Name="https" Value="BrowserTamerHTM" />
        </RegistryKey>
        <RegistryKey Root="HKCU" Key="Software\Clients\StartMenuInternet\BrowserTamer\Capabilities\FileAssociations">
            <RegistryValue Type="string" Name="htm" Value="BrowserTamerHTM" />
            <RegistryValue Type="string" Name="html" Value="BrowserTamerHTM" />
            <RegistryValue Type="string" Name="mht" Value="BrowserTamerHTM" />
            <RegistryValue Type="string" Name="mhtml" Value="BrowserTamerHTM" />
            <RegistryValue Type="string" Name="shtml" Value="BrowserTamerHTM" />
            <RegistryValue Type="string" Name="svg" Value="BrowserTamerHTM" />
            <RegistryValue Type="string" Name="webp" Value="BrowserTamerHTM" />
            <RegistryValue Type="string" Name="xht" Value="BrowserTamerHTM" />
            <RegistryValue Type="string" Name="xhtml" Value="BrowserTamerHTM" />
            <RegistryValue Type="string" Name="pdf" Value="BrowserTamerPDF" />
            <RegistryValue Type="string" Name="epub" Value="BrowserTamerEPUB" />
        </RegistryKey>

        <!-- protocol handlers referenced in URL/File associations -->
        <RegistryKey Root="HKCU" Key="Software\Classes\BrowserTamerHTM">
            <RegistryValue Type="string" Value="Browser Tamer Document" />
        </RegistryKey>
        <RegistryKey Root="HKCU" Key="Software\Classes\BrowserTamerHTM\Application">
            <RegistryValue Type="string" Name="ApplicationDescription" Value="Redirects open URLs to a browser of your choice." />
            <RegistryValue Type="string" Name="ApplicationName" Value="Browser Tamer" />
        </RegistryKey>
        <RegistryKey Root="HKCU" Key="Software\Classes\BrowserTamerHTM\DefaultIcon">
            <RegistryValue Type="string" Value="[#CM_FP_bt.exe],0" />
        </RegistryKey>
        <RegistryKey Root="HKCU" Key="Software\Classes\BrowserTamerHTM\shell\open\command">
            <RegistryValue Type="string" Value='"[#CM_FP_bt.exe]" %1' />
        </RegistryKey>

        <RegistryKey Root="HKCU" Key="Software\Classes\BrowserTamerPDF">
            <RegistryValue Type="string" Value="Browser Tamer Document" />
        </RegistryKey>
        <RegistryKey Root="HKCU" Key="Software\Classes\BrowserTamerPDF\Application">
            <RegistryValue Type="string" Name="ApplicationDescription" Value="Redirects open URLs to a browser of your choice." />
            <RegistryValue Type="string" Name="ApplicationName" Value="Browser Tamer" />
        </RegistryKey>
        <RegistryKey Root="HKCU" Key="Software\Classes\BrowserTamerPDF\DefaultIcon">
            <RegistryValue Type="string" Value="[#CM_FP_bt.exe],1" />
        </RegistryKey>
        <RegistryKey Root="HKCU" Key="Software\Classes\BrowserTamerPDF\shell\open\command">
            <RegistryValue Type="string" Value='"[#CM_FP_bt.exe]" %1' />
        </RegistryKey>

        <RegistryKey Root="HKCU" Key="Software\Classes\BrowserTamerEPUB">
            <RegistryValue Type="string" Value="Browser Tamer Document" />
        </RegistryKey>
        <RegistryKey Root="HKCU" Key="Software\Classes\BrowserTamerEPUB\Application">
            <RegistryValue Type="string" Name="ApplicationDescription" Value="Redirects open URLs to a browser of your choice." />
            <RegistryValue Type="string" Name="ApplicationName" Value="Browser Tamer" />
        </RegistryKey>
        <RegistryKey Root="HKCU" Key="Software\Classes\BrowserTamerEPUB\DefaultIcon">
            <RegistryValue Type="string" Value="[#CM_FP_bt.exe],2" />
        </RegistryKey>
        <RegistryKey Root="HKCU" Key="Software\Classes\BrowserTamerEPUB\shell\open\command">
            <RegistryValue Type="string" Value='"[#CM_FP_bt.exe]" %1' />
        </RegistryKey>

        <!-- register application -->
        <RegistryKey Root="HKCU" Key="Software\RegisteredApplications">
            <RegistryValue Type="string" Name="Browser Tamer" Value="Software\Clients\StartMenuInternet\BrowserTamer\Capabilities" />
        </RegistryKey>
        
    </CPackWiXFragment>
</CPackWiXPatch>
