<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
    <Fragment>
    <DirectoryRef Id="ProgramMenuFolder">
        <Directory Id="@APP_NAME@ShortcutFolder" Name="@APP_LONG_NAME@">
            <Component Id="ApplicationShortcut" Guid="9448E42D-FAEE-48A7-8045-C04D34010112">
                <Shortcut Id="ApplicationShortcut1"
                          Name="Configure @APP_LONG_NAME@"
                          Description="Configure @APP_LONG_NAME@"
                          Target="[INSTALLDIR]@APP_NAME@.exe"
                          WorkingDirectory="INSTALLDIR"/>
                <RemoveFolder Id="CleanUpShortCut" Directory="@APP_NAME@ShortcutFolder" On="uninstall"/>
                <RegistryValue Root="HKCU" Key="Software\@APP_LONG_NAME@" Name="installed" Type="integer" Value="1" KeyPath="yes"/>
            </Component>
        </Directory>
    </DirectoryRef>
    </Fragment>
</Wix>
